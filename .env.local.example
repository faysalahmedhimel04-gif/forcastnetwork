# ForcastNetwork - Supabase Configuration
# Copy this file to .env.local and fill in your values
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional but recommended for production / sitemap & robots
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Backend API URL (the separate forcastnetwork-backend project)
# For local dev: http://localhost:3001
# For production: your deployed backend URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Optional: Service role key only for admin scripts / seed (never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
