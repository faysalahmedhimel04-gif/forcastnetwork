# ForcastNetwork - Environment Configuration
# Copy this file to .env.local and fill in your values.
# IMPORTANT: Never commit real secrets. This file is for local development only.

# === Supabase (required for auth + DB) ===
# Get from Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# IMPORTANT for development: Disable email confirmation in your Supabase dashboard
# (Authentication > Settings > uncheck "Enable email confirmations") so sign up works immediately.
# The app also auto-confirms via backend service role for convenience in dev.
# See app/signup/page.tsx and backend/app/api/auth/confirm/route.ts
# NEXT_PUBLIC_AUTO_CONFIRM_EMAILS=true

# Optional (server-only, used in backend for privileged ops like accuracy recalc)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Backend API (separate forcastnetwork-backend deployment) ===
# This frontend talks to the backend for most data operations (recommended for prod)
# Optional for now: if not set, the frontend will attempt direct Supabase calls as fallback (for development / initial deploy)
# Set this to your backend URL (e.g. https://your-backend.vercel.app) once the backend is deployed
# NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# === Optional ===
# Your own frontend URL (used for sitemap, metadata, CORS on backend, etc.)
# NEXT_PUBLIC_FRONTEND_URL=https://your-production-domain.com
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
